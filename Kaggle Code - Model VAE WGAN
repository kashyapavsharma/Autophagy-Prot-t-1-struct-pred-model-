    "def train_hybrid_model(num_epochs=50):\n",
    "    vae.train()\n",
    "    generator.train()\n",
    "    discriminator.train()\n",
    "    \n",
    "    for epoch in range(num_epochs):\n",
    "        epoch_vae_loss = 0\n",
    "        epoch_gen_loss = 0\n",
    "        epoch_disc_loss = 0\n",
    "        \n",
    "        for batch_idx, (coords_batch, dist_batch) in enumerate(dataloader):\n",
    "            batch_size = coords_batch.size(0)\n",
    "            \n",
    "            # =====================================\n",
    "            # Phase 1: Train VAE (reconstruction)\n",
    "            # =====================================\n",
    "            vae_optimizer.zero_grad()\n",
    "            \n",
    "            recon_coords, mu, logvar = vae(coords_batch)\n",
    "            v_loss, recon_loss, kl_loss = vae_loss(recon_coords, coords_batch, mu, logvar)\n",
    "            \n",
    "            v_loss.backward()\n",
    "            vae_optimizer.step()\n",
    "            epoch_vae_loss += v_loss.item()\n",
    "            \n",
    "            # =====================================\n",
    "            # Phase 2: Train Discriminator\n",
    "            # =====================================\n",
    "            disc_optimizer.zero_grad()\n",
    "            \n",
    "            # Get latent representations\n",
    "            with torch.no_grad():\n",
    "                mu_real, _ = vae.encode(coords_batch)\n",
    "            \n",
    "            # Generate fake transitions\n",
    "            fake_transitions = generator(mu_real)  # [batch, 5, latent_dim]\n",
    "            \n",
    "            # Sample one of the 5 outputs for discriminator training\n",
    "            random_idx = torch.randint(0, 5, (batch_size,))\n",
    "            fake_z_t1 = fake_transitions[torch.arange(batch_size), random_idx]  # [batch, latent_dim]\n",
    "            \n",
    "            # Real transitions (use small noise as proxy for real folding steps)\n",
    "            noise = torch.randn_like(mu_real) * 0.1\n",
    "            real_z_t1 = mu_real + noise\n",
    "            \n",
    "            # Discriminator scores\n",
    "            real_score = discriminator(mu_real, real_z_t1)\n",
    "            fake_score = discriminator(mu_real, fake_z_t1.detach())\n",
    "            \n",
    "            # Wasserstein loss\n",
    "            d_loss = wasserstein_loss(real_score, fake_score)\n",
    "            d_loss.backward()\n",
    "            disc_optimizer.step()\n",
    "            epoch_disc_loss += d_loss.item()\n",
    "            \n",
    "            # =====================================\n",
    "            # Phase 3: Train Generator\n",
    "            # =====================================\n",
    "            gen_optimizer.zero_grad()\n",
    "            \n",
    "            # Generate all 5 transitions\n",
    "            fake_transitions = generator(mu_real)\n",
    "            \n",
    "            # Generator loss (fool discriminator + diversity)\n",
    "            g_loss = 0\n",
    "            for i in range(5):\n",
    "                fake_score = discriminator(mu_real, fake_transitions[:, i])\n",
    "                g_loss -= fake_score.mean()  # Maximize discriminator score\n",
    "            \n",
    "            # Add diversity loss\n",
    "            div_loss = diversity_loss(fake_transitions)\n",
    "            total_g_loss = g_loss + 0.1 * div_loss\n",
    "            \n",
    "            total_g_loss.backward()\n",
    "            gen_optimizer.step()\n",
    "            epoch_gen_loss += total_g_loss.item()\n",
    "        \n",
    "        # Print progress\n",
    "        if epoch % 10 == 0:\n",
    "            print(f\"Epoch {epoch:3d}: VAE={epoch_vae_loss/len(dataloader):.4f} \"\n",
    "                  f\"Gen={epoch_gen_loss/len(dataloader):.4f} \"\n",
    "                  f\"Disc={epoch_disc_loss/len(dataloader):.4f}\")\n",
    "\n",
    "print(\"✓ Fixed training function ready\")\n",
    "print(\"Starting training...\")\n",
    "train_hybrid_model(num_epochs=100)"
   ]
