    "from io import StringIO\n",
    "\n",
    "def analyze_chains(pdb_content):\n",
    "    \"\"\"Analyze what's in each chain\"\"\"\n",
    "    parser = PDBParser(QUIET=True)\n",
    "    structure = parser.get_structure('test', StringIO(pdb_content))\n",
    "    \n",
    "    for model in structure:\n",
    "        for chain in model:\n",
    "            residues = [r for r in chain if r.id[0] == ' ']\n",
    "            print(f\"Chain {chain.id}: {len(residues)} residues\")\n",
    "            if residues:\n",
    "                print(f\"  First: {residues[0].get_resname()}{residues[0].id[1]}\")\n",
    "                print(f\"  Last: {residues[-1].get_resname()}{residues[-1].id[1]}\")\n",
    "\n",
    "def extract_pik3c3_coords(pdb_content, chain_id='A'):\n",
    "    \"\"\"Extract backbone coordinates (N, CA, C, O) for PIK3C3\"\"\"\n",
    "    parser = PDBParser(QUIET=True)\n",
    "    pdb_io = StringIO(pdb_content)\n",
    "    structure = parser.get_structure('PIK3C3', pdb_io)\n",
    "    \n",
    "    coords = []\n",
    "    residue_info = []\n",
    "    backbone_atoms = ['N', 'CA', 'C', 'O']\n",
    "    \n",
    "    for model in structure:\n",
    "        for chain in model:\n",
    "            if chain.id == chain_id:\n",
    "                for residue in chain:\n",
    "                    if residue.id[0] == ' ':  # Standard amino acid\n",
    "                        residue_coords = []\n",
    "                        residue_complete = True\n",
    "                        \n",
    "                        for atom_name in backbone_atoms:\n",
    "                            if atom_name in residue:\n",
    "                                atom_coords = residue[atom_name].get_coord()\n",
    "                                residue_coords.append(atom_coords)\n",
    "                            else:\n",
    "                                residue_complete = False\n",
    "                                break\n",
    "                        \n",
    "                        if residue_complete:\n",
    "                            coords.extend(residue_coords)\n",
    "                            residue_info.append({\n",
    "                                'res_num': residue.id[1],\n",
    "                                'res_name': residue.get_resname(),\n",
    "                                'chain': chain.id\n",
    "                            })\n",
    "    \n",
    "    return np.array(coords), residue_info\n",
    "\n",
    "# Test both functions\n",
    "analyze_chains(test_pdb)\n",
    "coords, res_info = extract_pik3c3_coords(test_pdb, chain_id='A')\n",
    "print(f\"\\n✓ Extracted {len(coords)} atoms from {len(res_info)} residues\")"
   ]
