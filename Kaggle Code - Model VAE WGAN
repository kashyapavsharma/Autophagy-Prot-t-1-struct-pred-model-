    "def coords_to_pdb_format(coords, residue_info, pdb_id=\"PRED\"):\n",
    "    \"\"\"Convert coordinate array back to PDB format for ChimeraX loading\"\"\"\n",
    "    \n",
    "    pdb_lines = []\n",
    "    \n",
    "    # PDB header\n",
    "    pdb_lines.append(f\"HEADER    PROTEIN FOLDING PREDICTION           {pdb_id}\")\n",
    "    pdb_lines.append(f\"TITLE     GENERATED FOLDING STATE T+1\")\n",
    "    \n",
    "    atom_num = 1\n",
    "    backbone_atoms = ['N', 'CA', 'C', 'O']\n",
    "    \n",
    "    for res_idx, res_info in enumerate(residue_info):\n",
    "        for atom_idx, atom_name in enumerate(backbone_atoms):\n",
    "            if res_idx < coords.shape[0]:  # Make sure we don't exceed coordinate bounds\n",
    "                x, y, z = coords[res_idx, atom_idx]\n",
    "                \n",
    "                # PDB ATOM record format\n",
    "                line = (f\"ATOM  {atom_num:5d} {atom_name:<4s} \"\n",
    "                       f\"{res_info['res_name']} {res_info['chain']}\"\n",
    "                       f\"{res_info['res_num']:4d}    \"\n",
    "                       f\"{x:8.3f}{y:8.3f}{z:8.3f}\"\n",
    "                       f\"  1.00 20.00           {atom_name[0]}\")\n",
    "                \n",
    "                pdb_lines.append(line)\n",
    "                atom_num += 1\n",
    "    \n",
    "    pdb_lines.append(\"END\")\n",
    "    return \"\\n\".join(pdb_lines)\n",
    "\n",
    "def save_all_predictions(predicted_states, residue_info, base_name=\"folding_pred\"):\n",
    "    \"\"\"Save all 5 predictions as PDB files\"\"\"\n",
    "    saved_files = []\n",
    "    \n",
    "    for i, coords in enumerate(predicted_states):\n",
    "        pdb_content = coords_to_pdb_format(\n",
    "            coords, \n",
    "            residue_info, \n",
    "            pdb_id=f\"{base_name}_{i+1}\"\n",
    "        )\n",
    "        \n",
    "        filename = f\"{base_name}_t+1_state_{i+1}.pdb\"\n",
    "        with open(filename, 'w') as f:\n",
    "            f.write(pdb_content)\n",
    "        \n",
    "        saved_files.append(filename)\n",
    "        print(f\"✓ Saved: {filename}\")\n",
    "    \n",
    "    return saved_files\n",
