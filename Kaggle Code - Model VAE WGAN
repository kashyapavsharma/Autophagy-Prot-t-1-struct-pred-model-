    "class TransitionDiscriminator(nn.Module):\n",
    "    def __init__(self, latent_dim=64):\n",
    "        super(TransitionDiscriminator, self).__init__()\n",
    "        self.latent_dim = latent_dim\n",
    "        \n",
    "        # Input: two latent vectors [z_t, z_t1] concatenated\n",
    "        self.discriminator = nn.Sequential(\n",
    "            nn.Linear(latent_dim * 2, 256),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(256, 128),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(128, 64),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Linear(64, 1)  # Real vs Fake transition\n",
    "        )\n",
    "    \n",
    "    def forward(self, z_t, z_t1):\n",
    "        # Concatenate current and next state\n",
    "        combined = torch.cat([z_t, z_t1], dim=-1)\n",
    "        return self.discriminator(combined)\n",
    "\n",
    "# Initialize Discriminator\n",
    "discriminator = TransitionDiscriminator(latent_dim=64).to(device)\n",
    "print(f\"✓ Discriminator initialized\")"
