    "def generate_folding_steps(input_coords, num_outputs=5):\n",
    "    \"\"\"Generate 5 possible t+1 folding states from current structure\"\"\"\n",
    "    vae.eval()\n",
    "    generator.eval()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        # Get original number of residues\n",
    "        original_n_residues = input_coords.shape[0]\n",
    "        \n",
    "        # Pad to max_len (same as training data)\n",
    "        if original_n_residues < max_len:\n",
    "            padding = np.zeros((max_len - original_n_residues, 4, 3))\n",
    "            padded_coords = np.concatenate([input_coords, padding], axis=0)\n",
    "        else:\n",
    "            padded_coords = input_coords[:max_len]  # Truncate if larger\n",
    "        \n",
    "        # Convert to tensor and normalize\n",
    "        input_tensor = torch.FloatTensor(padded_coords).unsqueeze(0).to(device)\n",
    "        input_normalized = (input_tensor - coords_mean) / coords_std\n",
    "        \n",
    "        print(f\"Input shape after padding: {input_normalized.shape}\")\n",
    "        print(f\"Expected shape: [1, {max_len}, 4, 3]\")\n",
    "        \n",
    "        # Encode to latent space\n",
    "        mu, logvar = vae.encode(input_normalized)\n",
    "        \n",
    "        # Generate 5 possible next latent states\n",
    "        next_latents = generator(mu)  # [1, 5, latent_dim]\n",
    "        \n",
    "        # Decode each latent state back to coordinates\n",
    "        next_structures = []\n",
    "        for i in range(num_outputs):\n",
    "            decoded_coords = vae.decode(next_latents[0, i:i+1])  # [1, max_len, 4, 3]\n",
    "            \n",
    "            # Denormalize coordinates\n",
    "            denormalized = decoded_coords * coords_std + coords_mean\n",
    "            \n",
    "            # Remove padding - keep only original number of residues\n",
    "            unpadded = denormalized.squeeze(0)[:original_n_residues].cpu().numpy()\n",
    "            \n",
    "            next_structures.append(unpadded)\n",
    "    \n",
    "    return next_structures\n",
