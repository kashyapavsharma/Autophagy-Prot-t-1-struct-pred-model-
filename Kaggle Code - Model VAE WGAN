    "class ProteinVAE(nn.Module):\n",
    "    def __init__(self, max_residues, latent_dim=64):\n",
    "        super(ProteinVAE, self).__init__()\n",
    "        self.max_residues = max_residues\n",
    "        self.latent_dim = latent_dim\n",
    "        \n",
    "        # Flatten input: [batch, max_residues, 4, 3] -> [batch, max_residues*12]\n",
    "        input_dim = max_residues * 4 * 3\n",
    "        \n",
    "        # Encoder: coordinates -> latent space\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Linear(input_dim, 1024),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(1024, 512),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(512, 256),\n",
    "            nn.ReLU()\n",
    "        )\n",
    "        \n",
    "        # Latent space parameters\n",
    "        self.mu_layer = nn.Linear(256, latent_dim)\n",
    "        self.logvar_layer = nn.Linear(256, latent_dim)\n",
    "        \n",
    "        # Decoder: latent space -> coordinates\n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.Linear(latent_dim, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(256, 512),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(512, 1024),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(1024, input_dim)\n",
    "        )\n",
    "        \n",
    "    def encode(self, x):\n",
    "        # Flatten coordinates\n",
    "        x_flat = x.view(x.size(0), -1)\n",
    "        h = self.encoder(x_flat)\n",
    "        mu = self.mu_layer(h)\n",
    "        logvar = self.logvar_layer(h)\n",
    "        return mu, logvar\n",
    "    \n",
    "    def reparameterize(self, mu, logvar):\n",
    "        std = torch.exp(0.5 * logvar)\n",
    "        eps = torch.randn_like(std)\n",
    "        return mu + eps * std\n",
    "    \n",
    "    def decode(self, z):\n",
    "        x_flat = self.decoder(z)\n",
    "        x = x_flat.view(-1, self.max_residues, 4, 3)\n",
    "        return x\n",
    "    \n",
    "    def forward(self, x):\n",
    "        mu, logvar = self.encode(x)\n",
    "        z = self.reparameterize(mu, logvar)\n",
    "        x_recon = self.decode(z)\n",
    "        return x_recon, mu, logvar\n",
    "\n",
