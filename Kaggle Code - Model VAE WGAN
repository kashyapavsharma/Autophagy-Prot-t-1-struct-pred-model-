    "def validate_generated_coords(coords):\n",
    "    \"\"\"Check for common issues in generated coordinates\"\"\"\n",
    "    issues = []\n",
    "    \n",
    "    # Check for NaN or infinity\n",
    "    if np.isnan(coords).any():\n",
    "        issues.append(\"Contains NaN values\")\n",
    "    if np.isinf(coords).any():\n",
    "        issues.append(\"Contains infinity values\")\n",
    "    \n",
    "    # Check coordinate ranges (should be reasonable for proteins)\n",
    "    coord_ranges = np.ptp(coords, axis=(0,1))  # Range across residues and atoms\n",
    "    if (coord_ranges > 200).any():\n",
    "        issues.append(f\"Unrealistic coordinate range: {coord_ranges}\")\n",
    "    \n",
    "    # Check bond lengths (consecutive CA atoms should be ~3.8Å)\n",
    "    ca_coords = coords[:, 1, :]  # CA atoms\n",
    "    ca_distances = np.linalg.norm(ca_coords[1:] - ca_coords[:-1], axis=1)\n",
    "    weird_bonds = ((ca_distances < 2.0) | (ca_distances > 8.0)).sum()\n",
    "    if weird_bonds > 5:\n",
    "        issues.append(f\"{weird_bonds} unrealistic CA-CA distances\")\n",
    "    \n",
    "    return issues\n",
