    "# Loss functions\n",
    "def vae_loss(recon_coords, original_coords, mu, logvar, beta=1.0):\n",
    "    # Reconstruction loss (MSE)\n",
    "    recon_loss = F.mse_loss(recon_coords, original_coords, reduction='mean')\n",
    "    \n",
    "    # KL divergence\n",
    "    kl_loss = -0.5 * torch.sum(1 + logvar - mu.pow(2) - logvar.exp(), dim=1).mean()\n",
    "    \n",
    "    return recon_loss + beta * kl_loss, recon_loss, kl_loss\n",
    "\n",
    "def wasserstein_loss(real_scores, fake_scores):\n",
    "    return fake_scores.mean() - real_scores.mean()\n",
    "\n",
    "def diversity_loss(generated_outputs):\n",
    "    \"\"\"Encourage diversity among the 5 outputs\"\"\"\n",
    "    batch_size, n_outputs, latent_dim = generated_outputs.shape\n",
    "    \n",
    "    diversity = 0\n",
    "    for i in range(n_outputs):\n",
    "        for j in range(i+1, n_outputs):\n",
    "            # Penalize similar outputs\n",
    "            similarity = F.cosine_similarity(\n",
    "                generated_outputs[:, i], \n",
    "                generated_outputs[:, j], \n",
    "                dim=1\n",
    "            ).mean()\n",
    "            diversity -= similarity\n",
