    "def compute_distance_matrix(coords, residue_info):\n",
    "    \"\"\"Compute CA-CA distance matrix between residues\"\"\"\n",
    "    # Extract only CA coordinates (every 2nd coordinate: 0=N, 1=CA, 2=C, 3=O)\n",
    "    ca_coords = coords[1::4]  # CA atoms only\n",
    "    n_residues = len(ca_coords)\n",
    "    \n",
    "    # Compute pairwise distances\n",
    "    distance_matrix = np.zeros((n_residues, n_residues))\n",
    "    \n",
    "    for i in range(n_residues):\n",
    "        for j in range(n_residues):\n",
    "            if i == j:\n",
    "                distance_matrix[i, j] = 0.0\n",
    "            else:\n",
    "                dist = np.linalg.norm(ca_coords[i] - ca_coords[j])\n",
    "                distance_matrix[i, j] = dist\n",
    "    \n",
    "    return distance_matrix, ca_coords\n",
    "\n",
    "# Test distance matrix\n",
    "dist_matrix, ca_coords = compute_distance_matrix(coords, res_info)\n",
    "print(f\"Distance matrix shape: {dist_matrix.shape}\")\n",
    "print(f\"CA coordinates shape: {ca_coords.shape}\")\n",
    "print(f\"Min distance (non-zero): {np.min(dist_matrix[dist_matrix > 0]):.2f}Å\")\n",
    "print(f\"Max distance: {np.max(dist_matrix):.2f}Å\")\n",
    "\n",
    "# Visualize distance matrix\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.imshow(dist_matrix, cmap='viridis', aspect='auto')\n",
    "plt.colorbar(label='Distance (Å)')\n",
    "plt.title('PIK3C3 CA-CA Distance Matrix')\n",
    "plt.xlabel('Residue Index')\n",
    "plt.ylabel('Residue Index')\n",
    "plt.show()"
   ]
  },
