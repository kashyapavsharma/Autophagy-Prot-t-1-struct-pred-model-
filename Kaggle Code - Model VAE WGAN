    "def prepare_training_data(all_structures):\n",
    "    \"\"\"Prepare data for VAE-WGAN training\"\"\"\n",
    "    \n",
    "    # Find max length for padding\n",
    "    max_length = max(data['n_residues'] for data in all_structures.values())\n",
    "    \n",
    "    coords_list = []\n",
    "    distance_matrices = []\n",
    "    \n",
    "    for pdb_id, data in all_structures.items():\n",
    "        n_res = data['n_residues']\n",
    "        \n",
    "        # Reshape coordinates to [n_residues, 4, 3] (4 backbone atoms per residue)\n",
    "        coords = data['coords'].reshape(n_res, 4, 3)\n",
    "        \n",
    "        # Pad to max length if needed\n",
    "        if n_res < max_length:\n",
    "            padding = np.zeros((max_length - n_res, 4, 3))\n",
    "            coords_padded = np.vstack([coords, padding])\n",
    "        else:\n",
    "            coords_padded = coords\n",
    "            \n",
    "        # Pad distance matrix\n",
    "        dist_matrix = data['distance_matrix']\n",
    "        if n_res < max_length:\n",
    "            padded_dist = np.zeros((max_length, max_length))\n",
    "            padded_dist[:n_res, :n_res] = dist_matrix\n",
    "        else:\n",
    "            padded_dist = dist_matrix\n",
    "            \n",
    "        coords_list.append(coords_padded)\n",
    "        distance_matrices.append(padded_dist)\n",
    "    \n",
    "    return np.array(coords_list), np.array(distance_matrices), max_length\n",
    "\n",
    "# Prepare training data\n",
    "coords_array, dist_array, max_len = prepare_training_data(all_structures)\n",
    "print(f\"Training data prepared:\")\n",
    "print(f\"Coordinates shape: {coords_array.shape}\")  # [n_structures, max_residues, 4, 3]\n",
    "print(f\"Distance matrices shape: {dist_array.shape}\")  # [n_structures, max_residues, max_residues]\n",
    "print(f\"Max sequence length: {max_len}\")"
