    "class FoldingGenerator(nn.Module):\n",
    "    def __init__(self, latent_dim=64, n_outputs=5):\n",
    "        super(FoldingGenerator, self).__init__()\n",
    "        self.latent_dim = latent_dim\n",
    "        self.n_outputs = n_outputs\n",
    "        \n",
    "        # Shared layers for processing current state\n",
    "        self.shared = nn.Sequential(\n",
    "            nn.Linear(latent_dim, 128),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(128, 256),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(256, 128),\n",
    "            nn.ReLU()\n",
    "        )\n",
    "        \n",
    "        # Separate heads for each of the 5 outputs\n",
    "        self.output_heads = nn.ModuleList([\n",
    "            nn.Sequential(\n",
    "                nn.Linear(128, 64),\n",
    "                nn.ReLU(), \n",
    "                nn.Linear(64, latent_dim)\n",
    "            ) for _ in range(n_outputs)\n",
    "        ])\n",
    "        \n",
    "    def forward(self, z_t):\n",
    "        shared_features = self.shared(z_t)\n",
    "        \n",
    "        # Generate 5 different next states\n",
    "        outputs = []\n",
    "        for head in self.output_heads:\n",
    "            z_t1 = head(shared_features)\n",
    "            outputs.append(z_t1)\n",
    "            \n",
    "        return torch.stack(outputs, dim=1)  # [batch, 5, latent_dim]\n",
    "\n",
    "# Initialize Generator\n",
    "generator = FoldingGenerator(latent_dim=64, n_outputs=5).to(device)\n",
    "print(f\"✓ Generator initialized for 5 t+1 outputs\")"
   ]
