    "def process_all_structures():\n",
    "    all_data = {}\n",
    "    failed_downloads = []\n",
    "    \n",
    "    for i, pdb_id in enumerate(pdb_ids):\n",
    "        print(f\"\\n[{i+1}/16] Processing {pdb_id}...\")\n",
    "        \n",
    "        # Download PDB\n",
    "        pdb_content = download_pdb(pdb_id)\n",
    "        if not pdb_content:\n",
    "            failed_downloads.append(pdb_id)\n",
    "            continue\n",
    "            \n",
    "        try:\n",
    "            # Analyze chains\n",
    "            print(\"Chain analysis:\")\n",
    "            analyze_chains(pdb_content)\n",
    "            \n",
    "            # Extract coordinates (Chain A)\n",
    "            coords, res_info = extract_pik3c3_coords(pdb_content, chain_id='A')\n",
    "            \n",
    "            if len(coords) == 0:\n",
    "                print(f\"  ⚠️  No valid coordinates found for {pdb_id}\")\n",
    "                continue\n",
    "                \n",
    "            # Compute distance matrix\n",
    "            dist_matrix, ca_coords = compute_distance_matrix(coords, res_info)\n",
    "            \n",
    "            # Store results\n",
    "            all_data[pdb_id] = {\n",
    "                'coords': coords,\n",
    "                'ca_coords': ca_coords, \n",
    "                'distance_matrix': dist_matrix,\n",
    "                'residue_info': res_info,\n",
    "                'n_residues': len(res_info),\n",
    "                'n_atoms': len(coords)\n",
    "            }\n",
    "            \n",
    "            print(f\"  ✓ Success: {len(res_info)} residues, {len(coords)} atoms\")\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"  ✗ Failed processing {pdb_id}: {e}\")\n",
    "            failed_downloads.append(pdb_id)\n",
    "    \n",
    "    print(f\"\\n=== SUMMARY ===\")\n",
    "    print(f\"Successfully processed: {len(all_data)} structures\")\n",
    "    print(f\"Failed: {len(failed_downloads)} structures\")\n",
    "    if failed_downloads:\n",
    "        print(f\"Failed PDB IDs: {failed_downloads}\")\n",
    "    \n",
